# ── Splunk SOAR ────────────────────────────────────────────────────────────
SOAR_URL=https://YOUR_SOAR_IP:8443
SOAR_USERNAME=soar_local_admin
SOAR_PASSWORD=your_soar_password

# ── Splunk Enterprise ──────────────────────────────────────────────────────
SPLUNK_URL=https://YOUR_SPLUNK_IP:8089
HEC_URL=https://YOUR_SPLUNK_IP:8088

# ── Splunk tokens ──────────────────────────────────────────────────────────
# MCP Server bearer token (Settings → Token Management in Splunk)
SPLUNK_MCP_TOKEN=your_mcp_bearer_token_here

# HEC token (Settings → Data Inputs → HTTP Event Collector)
HEC_TOKEN=your_hec_token_here

# ── HuggingFace / Featherless AI ──────────────────────────────────────────
# huggingface.co → Settings → Access Tokens
HF_TOKEN=your_huggingface_token_here
